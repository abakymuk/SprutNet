{
  "name": "sprutnet",
  "version": "1.0.2",
  "private": true,
  "description": "MVP Shipping Planner - планировщик морских перевозок",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm shared:build && pnpm prisma:generate && pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "type-check": "pnpm shared:build && pnpm prisma:generate && pnpm --filter web type-check",
    "test": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "clean": "pnpm -r exec rm -rf node_modules && rm -rf node_modules",
    "shared:build": "pnpm --filter @sprutnet/shared build",
    "shared:dev": "pnpm --filter @sprutnet/shared dev",
    "prisma:generate": "pnpm exec prisma generate && cd apps/web && pnpm exec prisma generate --schema=../../prisma/schema.prisma && cd ../..",
    "prisma:push": "pnpm exec prisma db push",
    "prisma:studio": "pnpm exec prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.56.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^0.2.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "esbuild": "^0.25.9",
    "lucide-react": "^0.541.0",
    "next": "^15.5.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-day-picker": "^9.9.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "prisma": "5.22.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.15.0"
}
